{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
{
  "redirects": [
    {
      "source": "https://www.lyxup.app/:path*",
      "destination": "https://lyxup.app/:path*",
      "permanent": true
    }
  ]
}
